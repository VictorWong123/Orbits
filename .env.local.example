# =============================================================================
# Orbit — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# .env.local is gitignored and should NEVER be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# Found in: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# -----------------------------------------------------------------------------
# Supabase Service Role (required for event email reminders)
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# WARNING: This key bypasses RLS — never expose it to the browser.
# -----------------------------------------------------------------------------

SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# -----------------------------------------------------------------------------
# Cron Endpoint Security (required for event email reminders)
# Any strong random string. The /api/cron/event-email-reminders endpoint
# requires this as a Bearer token in the Authorization header.
# Generate one with: openssl rand -hex 32
# -----------------------------------------------------------------------------

CRON_SECRET=<random-secret>

# -----------------------------------------------------------------------------
# SMTP Email (required for event email reminders)
# Used by Nodemailer to send reminder emails.
#
# Gmail example:
#   EMAIL_SMTP_HOST=smtp.gmail.com
#   EMAIL_SMTP_USER=you@gmail.com
#   EMAIL_SMTP_PASS=<app-specific-password>
# -----------------------------------------------------------------------------

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_USER=you@example.com
EMAIL_SMTP_PASS=<smtp-password-or-app-password>

# Sender address shown in reminder emails (defaults to EMAIL_SMTP_USER).
# EMAIL_FROM=noreply@yourdomain.com

# SMTP port (defaults to 465 for implicit TLS). Use 587 for STARTTLS.
# EMAIL_SMTP_PORT=465
